# ── LLM Backend ──────────────────────────────────────────────────
# Options: "groq", "nvidia", "gemini", "ollama"
LLM_BACKEND=groq

# ── Groq (free: 14,400 req/day, no credit card) ─────────────────
# Sign up: console.groq.com
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── NVIDIA NIM (free: 1,000 credits on signup) ──────────────────
# Sign up: build.nvidia.com → Get API Key
NVIDIA_API_KEY=nvapi-your_key_here
NVIDIA_MODEL=meta/llama-3.1-405b-instruct

# ── Google Gemini (free: 1,000 req/day, no credit card) ─────────
# Get key: aistudio.google.com/apikey
GOOGLE_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Ollama (local, no key needed) ───────────────────────────────
OLLAMA_MODEL=llama3.2:3b
OLLAMA_CTX=8192

# ── LangSmith (optional tracing) ────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=verbal_autopsy_multiagent
